# YunoHost integration
SERVER_URL=https://__DOMAIN__
APP_PORT=__PORT__

# Tag mapping
TAG=latest

# Database
PG_DATABASE_NAME=twenty
PG_DATABASE_USER=twentyuser
PG_DATABASE_PASSWORD=__DB_PWD__

# Path mapping for Docker volumes
SERVER_LOCAL_DATA=__DATA_DIR__/server_data
DB_DATA_PATH=__DATA_DIR__/db

# App secrets
APP_SECRET=__APP_SECRET__
